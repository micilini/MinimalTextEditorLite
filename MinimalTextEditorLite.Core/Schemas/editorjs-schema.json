{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EditorJS Document",
  "type": "object",
  "required": [ "blocks" ],
  "properties": {
    "time": {
      "type": [ "integer", "number", "null" ]
    },
    "version": {
      "type": [ "string", "null" ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [ "type", "data" ],
        "properties": {
          "id": {
            "type": [ "string", "null" ]
          },
          "type": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
