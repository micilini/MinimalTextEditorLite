<Window x:Class="MinimalTextEditorLite.App.View.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinimalTextEditorLite.App.View"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        mc:Ignorable="d"
        Title="SplashScreenWindow"
        Height="460" Width="820"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{x:Null}"
        ContentRendered="Window_ContentRendered">

    <materialDesign:Card UniformCornerRadius="20"
                         Background="{DynamicResource MaterialDesignPaper}"
                         materialDesign:ShadowAssist.ShadowDepth="Depth5"
                         Margin="25">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Lado esquerdo: branding + loading ===== -->
            <Grid Grid.Column="0" Margin="40 36 30 36">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Linha do logo: ícone + título "Minimal Text Editor" + badge "LITE" -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Images/logo-mte.png"
                           Width="44" Height="44"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" />
                    <StackPanel Margin="14 0 0 0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Minimal Text Editor"
                                       FontFamily="{StaticResource MTE.Font.Primary}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       VerticalAlignment="Center" />
                            <Border Margin="10 2 0 0">
                                <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Splash_Screen_Lite}"
                                           FontFamily="{StaticResource MTE.Font.Primary}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource MTE.Brush.Primary}"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Descrição -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Splash_Screen_Description}"
                           Style="{StaticResource MTE.Text.Body}"
                           FontSize="14"
                           Margin="0 18 30 0" />

                <!-- Espaço flexível -->

                <!-- Loading text + progress bar no rodapé -->
                <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Splash_Screen_Loading_Message}"
                               Style="{StaticResource MTE.Text.Caption}"
                               FontSize="12"
                               Margin="0 0 0 10" />
                    <ProgressBar Name="progressBar"
                                 Value="{Binding ProgressValue}"
                                 IsIndeterminate="True"
                                 Width="320"
                                 HorizontalAlignment="Left"
                                 Style="{StaticResource MTE.ProgressBar.Brand}" />
                </StackPanel>
            </Grid>

            <!-- ===== Lado direito: imagem (PRESERVADA) ===== -->
            <Grid Grid.Column="1" Margin="0 30 30 30">
                <Image Source="pack://application:,,,/Assets/Images/image-splash-screen-lite.png"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Stretch="Uniform" />
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>
