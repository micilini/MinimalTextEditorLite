<Window x:Class="MinimalTextEditorLite.App.View.GlobalModals.GlobalModalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.GlobalModals"
        xmlns:helpers="clr-namespace:MinimalTextEditorLite.App.Helpers"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{StaticResource MTE.Font.Primary}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="GlobalModalsWindow"
        Height="410" Width="665">

    <Grid>
        <materialDesign:Card Style="{StaticResource MTE.Card.Modal}"
                             Width="540" Height="340">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== Header ===== -->
                <Grid Grid.Row="0" Margin="28 24 28 8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="12"
                                Background="{StaticResource MTE.Brush.PrimarySubtle}"
                                VerticalAlignment="Center">
                            <!-- A image vem do model (varia por modal). Mantida dinâmica. -->
                            <Image Source="{Binding GlobalModalModel.ImageSource, Mode=TwoWay}"
                                   Width="24" Height="24"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>
                        <Label Content="{Binding GlobalModalModel.HeaderContent, Mode=TwoWay}"
                               FontFamily="{StaticResource MTE.Font.Primary}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="14 0 0 0"
                               Padding="0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="0" Style="{StaticResource MTE.Divider}"
                        VerticalAlignment="Bottom" Margin="28 0 28 0" />

                <!-- ===== Body ===== -->
                <Grid Grid.Row="1">
                    <!-- Variante 1: campo de texto -->
                    <StackPanel Margin="28 16 28 16"
                                Visibility="{Binding GlobalModalModel.ShowTextField, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding LabelTextField, Mode=TwoWay}"
                                   Style="{StaticResource MTE.Text.SectionLabel}" />
                        <TextBox x:Name="MyTextBox"
                                 HorizontalAlignment="Stretch"
                                 Margin="0 12 0 0"
                                 Padding="12 8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 Height="42"
                                 FontFamily="{StaticResource MTE.Font.Primary}"
                                 FontSize="14"
                                 Foreground="{DynamicResource MaterialDesignBody}"
                                 materialDesign:HintAssist.Hint="{Binding GlobalModalModel.TextFieldHint, Mode=TwoWay}" />
                        <TextBlock x:Name="ErrorNullInput"
                                   FontFamily="{StaticResource MTE.Font.Primary}"
                                   FontSize="13"
                                   Foreground="{StaticResource MTE.Brush.Danger}"
                                   Margin="0 10 0 0" />
                    </StackPanel>

                    <!-- Variante 2: texto simples + check opcional -->
                    <StackPanel Margin="28 16 28 16"
                                Visibility="{Binding GlobalModalModel.ShowSimpleText, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock FontFamily="{StaticResource MTE.Font.Primary}"
                                   FontSize="15"
                                   FontWeight="Normal"
                                   LineHeight="22"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   TextWrapping="Wrap">
                            <Run Text="{Binding GlobalModalModel.SimpleTextContent, Mode=TwoWay}" />
                            <Bold>
                                <Run Text="{Binding GlobalModalModel.BoldTextContent, Mode=TwoWay}" />
                            </Bold>
                        </TextBlock>

                        <CheckBox Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Global_Modal_Dont_Show}"
                                  FontSize="13"
                                  FontFamily="{StaticResource MTE.Font.Primary}"
                                  Margin="0 18 0 0"
                                  Visibility="{Binding GlobalModalModel.ShowConfirmationCheck, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Checked="CheckBox_Checked"
                                  Unchecked="CheckBox_Unchecked" />
                    </StackPanel>
                </Grid>

                <!-- ===== Footer (Save / Cancel / Ok) ===== -->
                <Border Grid.Row="2" Style="{StaticResource MTE.Divider}"
                        VerticalAlignment="Top" Margin="28 0 28 0" />

                <Grid Grid.Row="2" Margin="28 16 28 22">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding GlobalModalModel.CancelButton.Text, Mode=TwoWay}"
                                Visibility="{Binding GlobalModalModel.CancelButton.IsVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource MTE.Button.Danger}"
                                MinWidth="96"
                                Margin="0 0 10 0" />

                        <Button Content="{Binding GlobalModalModel.SaveButton.Text, Mode=TwoWay}"
                                Visibility="{Binding GlobalModalModel.SaveButton.IsVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding NextCommand}"
                                Style="{StaticResource MTE.Button.Primary}"
                                MinWidth="96"
                                Margin="0 0 10 0" />

                        <Button Content="{Binding GlobalModalModel.OkButton.Text, Mode=TwoWay}"
                                Visibility="{Binding GlobalModalModel.OkButton.IsVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding OkCommand}"
                                Style="{StaticResource MTE.Button.Success}"
                                MinWidth="96" />
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
