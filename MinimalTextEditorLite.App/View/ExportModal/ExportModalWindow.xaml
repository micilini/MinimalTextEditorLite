<Window x:Class="MinimalTextEditorLite.App.View.ExportModal.ExportModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.ExportModal"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{StaticResource MTE.Font.Primary}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="ExportModalWindow"
        Height="600" Width="665">

    <Grid>
        <materialDesign:Card Style="{StaticResource MTE.Card.Modal}"
                             Width="540" Height="460">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                
                <Grid Grid.Row="0" Margin="28 24 28 8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="12"
                                Background="{StaticResource MTE.Brush.PrimarySubtle}"
                                VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ExportVariant"
                                                     Width="24" Height="24"
                                                     Foreground="{StaticResource MTE.Brush.Primary}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <Label Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Note_Title}"
                               Style="{StaticResource {x:Type Label}}"
                               FontFamily="{StaticResource MTE.Font.Primary}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="14 0 0 0"
                               Padding="0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="0" Style="{StaticResource MTE.Divider}"
                        VerticalAlignment="Bottom" Margin="28 0 28 0" />

                
                <StackPanel Grid.Row="1" Margin="28 16 28 16">
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Note_SubTitle}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />

                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Note_Message}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 6 0 0" />

                    <ComboBox x:Name="ExportComboBox"
                              Style="{StaticResource MTE.ComboBox.Form}"
                              Margin="0 18 0 0"
                              SelectionChanged="ExportComboBox_SelectionChanged">
                        <ComboBoxItem Content="JSON" />
                        <ComboBoxItem Content="Word (.doc)" />
                        <ComboBoxItem Content="HTML" />
                        <ComboBoxItem Content="Markdown (.md)" />
                        <ComboBoxItem Content="PDF" />
                    </ComboBox>

                    <StackPanel x:Name="MarkdownImageOptionsPanel"
                                Visibility="Collapsed"
                                Margin="0 18 0 0">
                        <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Markdown_ImageOptions_Title}"
                                   Style="{StaticResource MTE.Text.Body}" />
                        <ComboBox x:Name="MarkdownImageModeComboBox"
                                  Style="{StaticResource MTE.ComboBox.Form}"
                                  Margin="0 8 0 0">
                            <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Markdown_ImageMode_Embedded}" />
                            <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Markdown_ImageMode_Folder}" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource MTE.Divider}"
                        VerticalAlignment="Top" Margin="28 0 28 0" />

                <Grid Grid.Row="2" Margin="28 16 28 22">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Button_Close}"
                                Click="ButtonClose_Click"
                                Style="{StaticResource MTE.Button.Danger}"
                                MinWidth="96"
                                Margin="0 0 10 0" />
                        <Button x:Name="ButtonExport"
                                Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Export_Button}"
                                Click="ButtonExport_Click"
                                Style="{StaticResource MTE.Button.Primary}"
                                MinWidth="110" />
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>

