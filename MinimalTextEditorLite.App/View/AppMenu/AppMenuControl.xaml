<UserControl x:Class="MinimalTextEditorLite.App.View.AppMenu.AppMenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.AppMenu"
             xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
             mc:Ignorable="d"
             d:DesignHeight="40"
             d:DesignWidth="800">

    <Menu DockPanel.Dock="Top"
          Background="{DynamicResource MaterialDesignPaper}"
          Foreground="{DynamicResource MaterialDesignBody}"
          TextElement.Foreground="{DynamicResource MaterialDesignBody}"
          FontFamily="{StaticResource MTE.Font.Primary}"
          FontSize="13.5"
          Padding="14 6 8 6">

        <Menu.Resources>
            <Style x:Key="TopLevelMenuItem" TargetType="{x:Type MenuItem}">
                <Setter Property="Icon" Value="{x:Null}" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
                <Setter Property="FontFamily" Value="{StaticResource MTE.Font.Primary}" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="10 0" />
                <Setter Property="Margin" Value="2 0" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="templateRoot"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                </Border>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Fade"
                                       StaysOpen="False">
                                    <Border Background="{DynamicResource MaterialDesignPaper}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            MinWidth="220"
                                            Padding="6"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18"
                                                              ShadowDepth="3"
                                                              Opacity="0.28" />
                                        </Border.Effect>

                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    TextElement.Foreground="{DynamicResource MaterialDesignBody}" />
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource MTE.Brush.PrimarySubtle}" />
                                </Trigger>

                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource MTE.Brush.PrimarySubtle}" />
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SubMenuItem" TargetType="{x:Type MenuItem}">
                <Setter Property="Icon" Value="{x:Null}" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
                <Setter Property="FontFamily" Value="{StaticResource MTE.Font.Primary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Padding" Value="12 7" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="templateRoot"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        MinHeight="{TemplateBinding MinHeight}"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid TextElement.Foreground="{TemplateBinding Foreground}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="18" />
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.Column="0"
                                                          ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          Margin="0 0 16 0" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   FontFamily="{StaticResource MTE.Font.Primary}"
                                                   FontSize="12"
                                                   Opacity="0.72"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="18 0 0 0" />

                                        <TextBlock x:Name="submenuArrow"
                                                   Grid.Column="2"
                                                   Text="›"
                                                   FontFamily="{StaticResource MTE.Font.Primary}"
                                                   FontSize="18"
                                                   Opacity="0.72"
                                                   Visibility="Collapsed"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Right"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Fade"
                                       StaysOpen="False">
                                    <Border Background="{DynamicResource MaterialDesignPaper}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            MinWidth="220"
                                            Padding="6"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18"
                                                              ShadowDepth="3"
                                                              Opacity="0.28" />
                                        </Border.Effect>

                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    TextElement.Foreground="{DynamicResource MaterialDesignBody}" />
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="True">
                                    <Setter TargetName="submenuArrow" Property="Visibility" Value="Visible" />
                                </Trigger>

                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource MTE.Brush.PrimarySubtle}" />
                                </Trigger>

                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource MTE.Brush.PrimarySubtle}" />
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RecentFileMenuItem" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource SubMenuItem}">
                <Setter Property="Header" Value="{Binding FileName}" />
                <Setter Property="ToolTip" Value="{Binding FilePath}" />
                <EventSetter Event="Click" Handler="RecentFileMenuItem_Click" />
            </Style>

            <Style TargetType="{x:Type Separator}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Separator}">
                            <Border Height="1"
                                    Margin="8 5"
                                    Background="{DynamicResource MaterialDesignDivider}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Menu.Resources>

        <MenuItem Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File, StringFormat='_{0}'}"
                  Style="{StaticResource TopLevelMenuItem}">

            <MenuItem Tag="miNew"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_New, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding CreateNoteCommand}" />

            <MenuItem Tag="miOpen"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Open, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+O"
                      Command="{Binding OpenNoteCommand}" />

            <MenuItem Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Recent, StringFormat='_{0}'}"
                      Style="{StaticResource SubMenuItem}"
                      ItemsSource="{Binding RecentFiles}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource RecentFileMenuItem}" />
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <Separator />

            <MenuItem Tag="miSave"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Save, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+S"
                      Command="{Binding SaveNoteCommand}" />

            <MenuItem Tag="miMetadata"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Metadata, StringFormat='_{0}'}"
                      Command="{Binding MetadataCommand}" />

            <MenuItem Tag="miDelete"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Delete, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+Delete"
                      Command="{Binding DeleteNoteCommand}" />

            <Separator />

            <MenuItem Tag="miExport"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Export, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+Shift+E"
                      Command="{Binding ExportNoteCommand}" />

            <Separator />

            <MenuItem Tag="miConfiguration"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Configuration, StringFormat='_{0}'}"
                      InputGestureText="Ctrl+,"
                      Command="{Binding SettingsCommand}" />

            <Separator />

            <MenuItem Tag="miExit"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Exit, StringFormat='_{0}'}"
                      InputGestureText="Alt+F4"
                      Command="{Binding ExitCommand}" />
        </MenuItem>

        <MenuItem Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_Focus, StringFormat='_{0}'}"
                  Style="{StaticResource TopLevelMenuItem}"
                  Command="{Binding FocusModeCommand}"
                  InputGestureText="Ctrl+Shift+F" />

        <MenuItem Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_Help, StringFormat='_{0}'}"
                  Style="{StaticResource TopLevelMenuItem}">
            <MenuItem Tag="miAbout"
                      Style="{StaticResource SubMenuItem}"
                      Header="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_Help_About, StringFormat='_{0}'}"
                      Command="{Binding AboutCommand}" />
        </MenuItem>
    </Menu>
</UserControl>
