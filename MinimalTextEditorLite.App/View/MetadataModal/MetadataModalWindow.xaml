<Window x:Class="MinimalTextEditorLite.App.View.MetadataModal.MetadataModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{StaticResource MTE.Font.Primary}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="MetadataModalWindow"
        Height="560" Width="665"
        Loaded="Window_Loaded">

    <materialDesign:Card Style="{StaticResource MTE.Card.Modal}"
                         Width="540" Height="460">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="28 24 28 8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="12"
                            Background="{StaticResource MTE.Brush.PrimarySubtle}"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                                 Width="24" Height="24"
                                                 Foreground="{StaticResource MTE.Brush.Primary}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <Label Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Title}"
                           FontFamily="{StaticResource MTE.Font.Primary}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="14 0 0 0"
                           Padding="0" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="0" Style="{StaticResource MTE.Divider}"
                    VerticalAlignment="Bottom" Margin="28 0 28 0" />

            
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="28 16 28 8">
                <StackPanel>

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Field_Title}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MTE.Font.Primary}"
                             FontSize="14"
                             Height="38"
                             Padding="12 8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0 8 0 16" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Field_Slug}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBox Text="{Binding Slug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MTE.Font.Mono}"
                             FontSize="14"
                             Height="38"
                             Padding="12 8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0 8 0 16" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Field_Tags}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBox Text="{Binding Tags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MTE.Font.Primary}"
                             FontSize="14"
                             Height="38"
                             Padding="12 8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0 8 0 4" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Field_Tags_Hint}"
                               Style="{StaticResource MTE.Text.Caption}"
                               Margin="0 0 0 16" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Field_PublishDate}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <DatePicker SelectedDate="{Binding PublishDate, Mode=TwoWay}"
                                FontFamily="{StaticResource MTE.Font.Primary}"
                                FontSize="14"
                                Height="38"
                                Margin="0 8 0 0" />
                </StackPanel>
            </ScrollViewer>

            
            <Border Grid.Row="2" Style="{StaticResource MTE.Divider}"
                    VerticalAlignment="Top" Margin="28 0 28 0" />

            <Grid Grid.Row="2" Margin="28 16 28 22">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Button_Close}"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource MTE.Button.Danger}"
                            MinWidth="96"
                            Margin="0 0 10 0" />
                    <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Metadata_Save_Button}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource MTE.Button.Primary}"
                            MinWidth="110" />
                </StackPanel>
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>

