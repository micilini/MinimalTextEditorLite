<UserControl x:Class="MinimalTextEditorLite.App.View.Components.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.Components"
             xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="900">

    <Grid Margin="20 14 16 14" HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/Images/logo-mte.png"
                   Width="30" Height="30"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   VerticalAlignment="Center" />

            <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Minimal Text Editor"
                               FontFamily="{StaticResource MTE.Font.Primary}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Header_App_Version}"
                           FontFamily="{StaticResource MTE.Font.Primary}"
                           FontSize="11"
                           FontWeight="Normal"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0 2 0 0" />
            </StackPanel>
        </StackPanel>

        
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding OpenNoteCommand}"
                    ToolTip="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Open}"
                    Margin="0 0 4 0">
                <materialDesign:PackIcon Kind="FolderOpenOutline"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding SearchNoteCommand}"
                    ToolTip="Search"
                    Margin="0 0 4 0">
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding SaveNoteCommand}"
                    ToolTip="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Save}"
                    Margin="0 0 4 0">
                <materialDesign:PackIcon Kind="ContentSaveOutline"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>

            
            <Border Width="1" Height="22"
                    Background="{DynamicResource MaterialDesignDivider}"
                    Opacity="0.5"
                    Margin="8 0 8 0"
                    VerticalAlignment="Center" />

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding RemoveNoteCommand}"
                    ToolTip="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Delete}"
                    Margin="0 0 4 0">
                <materialDesign:PackIcon Kind="DeleteOutline"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding ExportCommand}"
                    ToolTip="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Export}"
                    Margin="0 0 4 0">
                <materialDesign:PackIcon Kind="ExportVariant"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>

            
            <Button Style="{StaticResource MTE.Button.IconGhost}"
                    Command="{Binding SettingsCommand}"
                    ToolTip="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=MenuItem_Header_File_Configuration}">
                <materialDesign:PackIcon Kind="CogOutline"
                                         Width="22" Height="22"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>

