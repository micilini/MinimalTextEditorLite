<Window x:Class="MinimalTextEditorLite.App.View.SettingsModal.SettingsModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.SettingsModal"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{StaticResource MTE.Font.Primary}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="SettingsModalWindow"
        Height="600" Width="665"
        Loaded="Window_Loaded">

    <materialDesign:Card Style="{StaticResource MTE.Card.Modal}"
                         Width="540" Height="500">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="28 24 28 8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="12"
                            Background="{StaticResource MTE.Brush.PrimarySubtle}"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CogOutline"
                                                 Width="24" Height="24"
                                                 Foreground="{StaticResource MTE.Brush.Primary}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <Label Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Title}"
                           FontFamily="{StaticResource MTE.Font.Primary}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="14 0 0 0"
                           Padding="0" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="0" Style="{StaticResource MTE.Divider}"
                    VerticalAlignment="Bottom" Margin="36 0 36 0" />

            
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0">

                <StackPanel Margin="36 18 36 10">

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Description}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <ComboBox x:Name="AutoSaveComboBox"
                              Style="{StaticResource MTE.ComboBox.Form}"
                              Margin="0 12 0 0"
                              SelectedIndex="{Binding SelectedAutoSaveIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_0}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_1}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_2}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_3}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_4}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_5}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_AutoSave_Choice_6}" />
                    </ComboBox>

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Language}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Language_Description}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <ComboBox x:Name="LanguageComboBox"
                              Style="{StaticResource MTE.ComboBox.Form}"
                              Margin="0 12 0 0"
                              SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Language_Choice_0}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Language_Choice_1}" />
                    </ComboBox>

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Theme}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Theme_Description}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <ComboBox x:Name="ThemeComboBox"
                              Style="{StaticResource MTE.ComboBox.Form}"
                              Margin="0 12 0 0"
                              SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Theme_Choice_Light}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Theme_Choice_Dark}" />
                        <ComboBoxItem Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Theme_Choice_System}" />
                    </ComboBox>

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Markdown_Title}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Markdown_Description}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <CheckBox Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Markdown_FrontMatter}"
                              IsChecked="{Binding ExportFrontMatterYaml, Mode=TwoWay}"
                              Margin="0 12 0 0"
                              FontSize="13" />

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_FileAssociation_Title}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_FileAssociation_Description}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <CheckBox Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_FileAssociation_Checkbox}"
                              IsChecked="{Binding AssociateFilesWithApp, Mode=TwoWay}"
                              Margin="0 12 0 0"
                              FontSize="13" />

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Backup_Title}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock x:Name="BackupFilesInfo"
                               Text="{Binding BackupFilesText, Mode=TwoWay}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Backup_Open_Button}"
                                Command="{Binding OpenBackupFolderCommand}"
                                Style="{StaticResource MTE.Button.Primary}"
                                MinWidth="118"
                                Margin="0 0 8 0" />
                        <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Backup_Button}"
                                Command="{Binding DeleteBackupCommand}"
                                Style="{StaticResource MTE.Button.Danger}"
                                MinWidth="118" />
                    </StackPanel>

                    <Border Style="{StaticResource MTE.Divider}" />

                    
                    <TextBlock Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Title_System_Messages}"
                               Style="{StaticResource MTE.Text.SectionLabel}" />
                    <TextBlock x:Name="SystemMessagesRestoration"
                               Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Description_System_Messages}"
                               Style="{StaticResource MTE.Text.Body}"
                               Margin="0 4 0 0" />
                    <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Modal_Settings_Button_Restore}"
                            Command="{Binding RestoreMessagesCommand}"
                            Style="{StaticResource MTE.Button.Primary}"
                            HorizontalAlignment="Left"
                            MinWidth="118"
                            Margin="0 12 0 4" />
                </StackPanel>
            </ScrollViewer>

            
            <Border Grid.Row="2" Style="{StaticResource MTE.Divider}"
                    VerticalAlignment="Top" Margin="36 0 36 0" />

            <Grid Grid.Row="2" Margin="36 16 36 22">
                <Button Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=Button_Close}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MTE.Button.Danger}"
                        HorizontalAlignment="Right"
                        MinWidth="96" />
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>

