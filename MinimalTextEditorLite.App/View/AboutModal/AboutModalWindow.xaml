<Window x:Class="MinimalTextEditorLite.App.View.AboutModal.AboutModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinimalTextEditorLite.App.View.AboutModal"
        xmlns:localApp="clr-namespace:MinimalTextEditorLite.App"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{StaticResource MTE.Font.Primary}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="AboutModalWindow"
        Height="540" Width="665">

    <materialDesign:Card Style="{StaticResource MTE.Card.Modal}"
                         Width="540" Height="420">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="28 20 14 8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="12"
                            Background="{StaticResource MTE.Brush.PrimarySubtle}"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Width="24" Height="24"
                                                 Foreground="{StaticResource MTE.Brush.Primary}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <Label Content="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=About_Title}"
                           FontFamily="{StaticResource MTE.Font.Primary}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="14 0 0 0"
                           Padding="0" />
                </StackPanel>

                
                <Border Width="40" Height="40"
                        CornerRadius="10"
                        Background="Transparent"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip="Close"
                        MouseLeftButtonUp="OnCloseIconClicked">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource MTE.Brush.IconHoverBg}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <materialDesign:PackIcon Kind="Close"
                                             Width="20" Height="20"
                                             Foreground="{DynamicResource MaterialDesignBody}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                </Border>
            </Grid>

            <Border Grid.Row="0" Style="{StaticResource MTE.Divider}"
                    VerticalAlignment="Bottom" Margin="28 0 28 0" />

            
            <StackPanel Grid.Row="1" Margin="28 16 28 8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=About_Title_Id}"
                               FontFamily="{StaticResource MTE.Font.Primary}"
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               x:Name="AppId"
                               Text=""
                               FontFamily="{StaticResource MTE.Font.Mono}"
                               FontSize="13"
                               FontWeight="Normal"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center"
                               Margin="10 0 0 0"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{Binding Source={x:Static localApp:App.Localization}, Converter={StaticResource Translate}, ConverterParameter=About_Title_Current_Version}"
                               FontFamily="{StaticResource MTE.Font.Primary}"
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               VerticalAlignment="Center"
                               Margin="0 8 0 0" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               x:Name="AppV"
                               Text=""
                               FontFamily="{StaticResource MTE.Font.Mono}"
                               FontSize="13"
                               FontWeight="Normal"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center"
                               Margin="10 8 0 0" />
                </Grid>

                <TabControl Margin="0 20 0 0" Height="180">
                    <TabItem Header="MIT License">
                        <Border Background="{DynamicResource MaterialDesignDivider}"
                                Opacity="0.18"
                                CornerRadius="6"
                                Margin="0 8 0 0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="14">
                                <TextBlock TextWrapping="Wrap"
                                           FontFamily="{StaticResource MTE.Font.Mono}"
                                           FontSize="12"
                                           LineHeight="17"
                                           Foreground="{DynamicResource MaterialDesignBody}">
MIT License

Copyright (c) 2025-2026 Micilini Roll

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
                                </TextBlock>
                            </ScrollViewer>
                        </Border>
                    </TabItem>
                </TabControl>
            </StackPanel>

            
            <Grid Grid.Row="2" Margin="28 8 28 18">
                <TextBlock Text="Portal Micilini · 2025-2026"
                           Style="{StaticResource MTE.Text.Caption}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>

